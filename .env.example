# tonespeak project secrets -- project-scoped, NOT system-wide.
#
# Copy this file to `.env.local` and paste your values after the `=`.
# `.env.local` is gitignored:  it is never committed and never leaves your machine.
# Because it is untracked, it never reaches Gitea or the public GitHub mirror.
#
# ANTHROPIC_API_KEY -- the eval harness (evals/three-arm-eval.js) loads `.env.local`
# then `.env` automatically;  a real environment variable, if already set, wins.
# Required only for `--strict` (bare-mode) runs -- see evals/README.md.
# Generate a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# GITHUB_PAT -- Personal Access Token used by scripts/publish.ps1 to push the public
# mirror.  Needs push / contents:write on grayminds/tonespeak.  Read for the single
# push only;  never printed, never written to git config, never the global cache.
GITHUB_PAT=ghp_...

# GITEA_TOKEN -- OPTIONAL Gitea personal access token.  When set, scripts/publish.ps1
# authenticates the Gitea push with it (GCM cleared) instead of relying on cached
# credentials -- the most stable option across fresh clones and other hosts.  Leave it
# unset to use git's existing Gitea credentials.
GITEA_TOKEN=
